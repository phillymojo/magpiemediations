generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum VerificationStatus {
  PENDING    // Application received; under review
  ACTIVE     // Verified — visible on the public roster
  SUSPENDED  // Temporarily removed (e.g., bar issue under investigation)
  WITHDRAWN  // Voluntarily left the platform
}

// ─── Models ───────────────────────────────────────────────────────────────────

// Platform user — synced from Clerk via webhook on user.created/updated/deleted.
// id is Clerk's user ID ("user_xxxxxxxxxxxx") — no separate UUID needed.
// Hard delete for MVP; must change to soft delete before bookings feature ships.
model User {
  id        String   @id
  email     String   @unique
  firstName String
  lastName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Mediator {
  id                 String               @id @default(uuid())
  firstName          String
  lastName           String
  firm               String               // Law firm name, or "Solo Practice"
  city               String
  state              String               // ISO 3166-2 US state code: "CA", "TX", etc.
  yearsOfPractice    Int
  slug               String               @unique
  verificationStatus VerificationStatus   @default(PENDING)
  practiceAreas      MediatorPracticeArea[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([verificationStatus])           // roster query always filters on this
  @@index([state])                        // state filter
  @@index([lastName, firstName])          // default alphabetical sort
}

model PracticeArea {
  id        String               @id @default(uuid())
  name      String               @unique   // Display name: "Personal Injury"
  slug      String               @unique   // URL/filter value: "personal-injury"
  mediators MediatorPracticeArea[]
}

// Join table: many-to-many between Mediator and PracticeArea.
// Many-to-many is required by spec (a mediator may have multiple practice
// areas) and keeps the data model multi-select-ready per FR-007.
model MediatorPracticeArea {
  mediatorId     String
  practiceAreaId String
  mediator       Mediator     @relation(fields: [mediatorId], references: [id], onDelete: Cascade)
  practiceArea   PracticeArea @relation(fields: [practiceAreaId], references: [id])

  @@id([mediatorId, practiceAreaId])
  @@index([practiceAreaId])               // efficient filter: "mediators in area X"
}
